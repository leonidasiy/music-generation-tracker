{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leonidasiy.github.io/music-generation-tracker/schemas/clpr-stage0-run-manifest-0.1.0.json",
  "title": "CLPR Stage 0 Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "run_id", "pair_id", "condition", "generator", "generation",
    "environment", "output", "regions", "failures", "cost_usd",
    "cumulative_stage0_cost_usd", "created_at"
  ],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "run_id": {"type": "string", "minLength": 1},
    "pair_id": {"type": "string", "minLength": 1},
    "condition": {"enum": ["control", "intervention"]},
    "generator": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "access_type", "version", "interface"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "access_type": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "interface": {"type": "string", "minLength": 1},
        "subscription_tier": {"type": ["string", "null"]},
        "source_revision": {"type": ["string", "null"]}
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": true,
      "required": ["submitted_prompt", "duration_requested_sec", "seed", "seed_status", "settings", "prompt_rewriting"],
      "properties": {
        "submitted_prompt": {"type": "string", "minLength": 1},
        "duration_requested_sec": {"type": "number", "exclusiveMinimum": 0},
        "seed": {"type": ["integer", "null"]},
        "seed_status": {"enum": ["fixed", "random", "unavailable"]},
        "settings": {"type": "object"},
        "prompt_rewriting": {"type": "boolean"}
      }
    },
    "environment": {"type": "object"},
    "output": {
      "type": "object",
      "additionalProperties": true,
      "required": ["path", "sha256", "duration_observed_sec", "sample_rate_hz", "channels", "size_bytes"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "duration_observed_sec": {"type": "number", "exclusiveMinimum": 0},
        "sample_rate_hz": {"type": "integer", "exclusiveMinimum": 0},
        "channels": {"type": "integer", "exclusiveMinimum": 0},
        "size_bytes": {"type": "integer", "exclusiveMinimum": 0}
      }
    },
    "regions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "class", "start_sec", "end_sec"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "class": {"enum": ["target", "strict_preservation", "adaptation_allowed", "out_of_scope"]},
          "start_sec": {"type": "number", "minimum": 0},
          "end_sec": {"type": "number", "exclusiveMinimum": 0}
        }
      }
    },
    "failures": {"type": "array", "items": {"type": "string"}},
    "cost_usd": {"type": "number", "minimum": 0},
    "cumulative_stage0_cost_usd": {"type": "number", "minimum": 0, "maximum": 100},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
